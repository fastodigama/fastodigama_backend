extends ../common/layout

block layout-content
    .row.justify-content-center
        .col-lg-10
            .card.shadow-sm
                .card-body.p-4
                    h1.h3.mb-4.text-center Edit Article

                    // Form sends updated data to /admin/article/edit/submit
                    form#edit-article-form(action="/admin/article/edit/submit", method="post", enctype="multipart/form-data", autocomplete="off")
                        // Hidden field: article ID
                        input(type="hidden", name="articleId", value=editArticle._id)

                        // Title field
                        .mb-3
                            label.form-label(for="title") Title
                            input.form-control(
                                type="text",
                                id="title",
                                name="title",
                                value=editArticle.title,
                                required
                            )

                        .mb-3
                            label.form-label(for="arabicTitle") Arabic Title
                            input.form-control(
                                type="text",
                                id="arabicTitle",
                                name="arabicTitle",
                                dir="rtl",
                                value=(editArticle && editArticle.translations && editArticle.translations.ar && editArticle.translations.ar.title) || "",
                                placeholder="Optional Arabic title"
                            )
                            .form-text Leave blank to auto-translate with OpenAI.

                        //- 🌟 NEW: Author field
                        if lockedAuthor
                            .mb-3
                                label.form-label Author
                                input.form-control(
                                    type="text",
                                    value=lockedAuthor.name,
                                    readonly
                                )
                                input(type="hidden", id="authorId", name="authorId", value=lockedAuthor._id)
                                input(type="hidden", id="author", name="author", value=lockedAuthor.name)
                                .form-text This article will stay assigned to your linked author profile.
                        else
                            .mb-3
                                label.form-label(for="authorId") Author
                                select.form-select(id="authorId", name="authorId")
                                    option(value="") Select an author
                                    each item in authors
                                        option(
                                            value=item._id,
                                            selected=(editArticle.authorId && String(item._id) === String(editArticle.authorId._id))
                                        )= item.name
                                .form-text Choose an existing author record. If left empty, the legacy author name below will be used.

                            .mb-3
                                label.form-label(for="author") Legacy Author Name
                                input.form-control(
                                    type="text",
                                    id="author",
                                    name="author",
                                    value=editArticle.author || "",
                                    placeholder="Optional if no author is selected above"
                                )

                        //- Article text field
                        .mb-3
                            label.form-label(for="article-text") Article Text
                            .card.border-0.bg-light.mb-2
                                .card-body.py-2
                                    .d-flex.flex-wrap.gap-2.article-markdown-toolbar(data-target="article-text")
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="bold") Bold
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="italic") Italic
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="quote") Quote
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="heading") Heading
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="link") Link
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="bullets") Bullets
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="numbered") Numbered List
                                        button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="table") Table
                            .form-text.mb-2 Use Markdown for formatting like bold, italics, quotes, headings, links, and lists.
                            textarea.form-control(
                                id="article-text",
                                name="text",
                                rows="10",
                                autocomplete="off",
                                required
                            )= editArticle.text

                        .mb-3
                            label.form-label(for="arabic-article-text") Arabic Article Text
                            .form-text.mb-2 Optional manual Arabic body. Leave blank to auto-translate with OpenAI.
                            textarea.form-control(
                                id="arabic-article-text",
                                name="arabicText",
                                rows="10",
                                dir="rtl",
                                autocomplete="off",
                                placeholder="اكتب النص العربي هنا..."
                            )= (editArticle && editArticle.translations && editArticle.translations.ar && editArticle.translations.ar.text) || ""

                        // Category dropdown (preloaded)
                        .mb-3
                            label.form-label(for="cat") Select Category
                            select.form-select(id="cat", name="categoryId", required)
                                option(value="") Choose a category
                                each cat in categories
                                    option(
                                        value=cat._id,
                                        selected=cat._id.toString() === editArticle.categoryId._id.toString()
                                    )= cat.name

                        //- Display existing images WITH EDITABLE CAPTIONS
                        if editArticle.images && editArticle.images.length > 0
                            .mb-4
                                label.form-label.fw-bold Existing Images
                                .row.g-3#existingImages
                                    each image, index in editArticle.images
                                        .col-md-4.image-card(data-image-index=index, data-image-key=image.key, data-article-id=editArticle._id)
                                            .card.position-relative.h-100
                                                img.card-img-top(src=image.url, alt=image.alt || editArticle.title)
                                                .card-body.p-3.d-flex.flex-column
                                                    label.form-label.small.text-muted Edit Caption:
                                                    
                                                    // Hidden input so backend knows WHICH image this is
                                                    input(type="hidden", name="existingImageKeys", value=image.key)
                                                    
                                                    // Editable input for the caption
                                                    input.form-control.form-control-sm.mb-3(
                                                        type="text",
                                                        name="existingImageAlts",
                                                        value=image.alt,
                                                        placeholder="Enter caption..."
                                                    )
                                                    
                                                    button.btn.btn-danger.btn-sm.w-100.mt-auto.delete-image-btn(type="button")
                                                        i.bi.bi-trash.me-1
                                                        | Delete

                        //- Add new images section
                        .mb-4
                            .card.bg-light
                                .card-body
                                    label.form-label.fw-bold
                                        i.bi.bi-cloud-upload.me-2
                                        | Add New Images (optional)
                                    
                                    #image-container
                                        // The first block (NOT required for edit)
                                        .image-block.border.rounded.p-3.mb-3.bg-white
                                            .row
                                                .col-md-6.mb-2.mb-md-0
                                                    label.form-label.small Upload Image
                                                    input.form-control(
                                                        type="file",
                                                        name="images",
                                                        accept="image/*"
                                                    )
                                                .col-md-6
                                                    label.form-label.small Image Caption (Source / Alt text)
                                                    input.form-control(
                                                        type="text",
                                                        name="alt",
                                                        placeholder="e.g., Photo by Reuters / TSMC Factory"
                                                    )
                                    
                                    // Button to dynamically add more image/caption blocks
                                    button#add-more-images.btn.btn-outline-secondary.btn-sm(type="button")
                                        | + Add Another Image

                        // Buttons
                        .d-flex.justify-content-end.gap-2.mt-4
                            a.btn.btn-secondary(href="/admin/article") Cancel
                            button#edit-submit-btn.btn.btn-dark(type="submit")
                                span#edit-submit-spinner.spinner-border.spinner-border-sm.d-none.me-2(role="status", aria-hidden="true")
                                span#edit-submit-text Save Changes

                        // FAQs (optional)
                        .mb-4
                            label.form-label.fw-bold Article FAQs (Optional)
                            #faq-container
                                if editArticle.faqs && editArticle.faqs.length > 0
                                    each faq, idx in editArticle.faqs
                                        .faq-block.border.rounded.p-3.mb-3.bg-light
                                            .row
                                                .col-md-6.mb-2.mb-md-0
                                                    label.form-label.small.fw-bold.faq-question-label FAQ Question #{idx+1}
                                                    input.form-control(
                                                        type="text",
                                                        name="faqQuestions",
                                                        value=faq.question,
                                                        placeholder="e.g., What is the best way to embed a YouTube video?"
                                                    )
                                                .col-md-6
                                                    label.form-label.small FAQ Answer
                                                    input.form-control(
                                                        type="text",
                                                        name="faqAnswers",
                                                        value=faq.answer,
                                                        placeholder="e.g., Use the YouTube embed code (iframe) in your article text."
                                                    )
                                else
                                    .faq-block.border.rounded.p-3.mb-3.bg-light
                                        .row
                                            .col-md-6.mb-2.mb-md-0
                                                label.form-label.small.fw-bold.text-primary.faq-question-label FAQ Question 1
                                                input.form-control(
                                                    type="text",
                                                    name="faqQuestions",
                                                    placeholder="e.g., What is the best way to embed a YouTube video?"
                                                )
                                            .col-md-6
                                                label.form-label.small FAQ Answer
                                                input.form-control(
                                                    type="text",
                                                    name="faqAnswers",
                                                    placeholder="e.g., Use the YouTube embed code (iframe) in your article text."
                                                )
                            button#add-more-faqs.btn.btn-outline-secondary.btn-sm(type="button")
                                | + Add Another Question

                        .mb-4
                            label.form-label.fw-bold Article Sources (Optional)
                            #sources-container
                                if editArticle.sources && editArticle.sources.length > 0
                                    each source, idx in editArticle.sources
                                        .source-block.border.rounded.p-3.mb-3.bg-light
                                            .row
                                                .col-md-6.mb-2.mb-md-0
                                                    label.form-label.small.fw-bold.source-title-label Source Title #{idx+1}
                                                    input.form-control(
                                                        type="text",
                                                        name="sourceTitles",
                                                        value=source.title,
                                                        placeholder="e.g., World Bank Report 2026"
                                                    )
                                                .col-md-6
                                                    label.form-label.small Source URL
                                                    input.form-control(
                                                        type="url",
                                                        name="sourceUrls",
                                                        value=source.url,
                                                        placeholder="https://example.com/report"
                                                    )
                                else
                                    .source-block.border.rounded.p-3.mb-3.bg-light
                                        .row
                                            .col-md-6.mb-2.mb-md-0
                                                label.form-label.small.fw-bold.text-primary.source-title-label Source Title 1
                                                input.form-control(
                                                    type="text",
                                                    name="sourceTitles",
                                                    placeholder="e.g., World Bank Report 2026"
                                                )
                                            .col-md-6
                                                label.form-label.small Source URL
                                                input.form-control(
                                                    type="url",
                                                    name="sourceUrls",
                                                    placeholder="https://example.com/report"
                                                )
                            button#add-more-sources.btn.btn-outline-secondary.btn-sm(type="button")
                                | + Add Another Source

                        // Embed Video (optional)
                        .mb-3
                            label.form-label(for="embedVideo") Embed Video (YouTube iframe or link, optional)
                            .input-group
                                input.form-control(
                                    type="text",
                                    id="embedVideo",
                                    name="embedVideo",
                                    value=editArticle.embedVideo || "",
                                    placeholder="Paste YouTube embed code or link (optional)"
                                )
                                button#delete-video-btn.btn.btn-outline-danger(
                                    type="button",
                                    disabled=!editArticle.embedVideo
                                ) Delete Video
                            .form-text.text-muted Clearing the field or using Delete Video will remove the saved YouTube embed on save.
                        // Video Position (hero/inline)
                        .mb-3
                            label.form-label(for="embedVideoPosition") Video Position
                            select.form-select(
                                id="embedVideoPosition",
                                name="embedVideoPosition"
                            )
                                option(value="inline", selected=editArticle.embedVideoPosition === 'inline') Inline (inside article)
                                option(value="hero", selected=editArticle.embedVideoPosition === 'hero') Hero (top of article)
    //- Image clone and delete script
    script.
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('edit-article-form');
            const submitBtn = document.getElementById('edit-submit-btn');
            const submitSpinner = document.getElementById('edit-submit-spinner');
            const submitText = document.getElementById('edit-submit-text');
            const embedVideoInput = document.getElementById('embedVideo');
            const embedVideoPositionSelect = document.getElementById('embedVideoPosition');
            const deleteVideoBtn = document.getElementById('delete-video-btn');
            const markdownToolbar = document.querySelector('.article-markdown-toolbar');
            const articleTextarea = document.getElementById('article-text');

            const wrapSelection = (textarea, before, after = before, fallback = 'text') => {
                const start = textarea.selectionStart ?? 0;
                const end = textarea.selectionEnd ?? 0;
                const selected = textarea.value.slice(start, end) || fallback;
                const replacement = `${before}${selected}${after}`;
                textarea.setRangeText(replacement, start, end, 'select');
                textarea.focus();
            };

            const prefixLines = (textarea, prefix, fallback = 'List item') => {
                const start = textarea.selectionStart ?? 0;
                const end = textarea.selectionEnd ?? 0;
                const selected = textarea.value.slice(start, end) || fallback;
                const replacement = selected
                    .split('\n')
                    .map((line, index) => `${typeof prefix === 'function' ? prefix(index) : prefix}${line || fallback}`)
                    .join('\n');
                textarea.setRangeText(replacement, start, end, 'select');
                textarea.focus();
            };

            if (markdownToolbar && articleTextarea) {
                markdownToolbar.addEventListener('click', function(event) {
                    const button = event.target.closest('[data-md-action]');
                    if (!button) return;

                    const action = button.getAttribute('data-md-action');
                    switch (action) {
                        case 'bold':
                            wrapSelection(articleTextarea, '**', '**', 'bold text');
                            break;
                        case 'italic':
                            wrapSelection(articleTextarea, '*', '*', 'italic text');
                            break;
                        case 'quote':
                            prefixLines(articleTextarea, '> ', 'Quoted text');
                            break;
                        case 'heading':
                            prefixLines(articleTextarea, '## ', 'Heading');
                            break;
                        case 'link':
                            wrapSelection(articleTextarea, '[', '](https://example.com)', 'link text');
                            break;
                        case 'bullets':
                            prefixLines(articleTextarea, '- ', 'List item');
                            break;
                        case 'numbered':
                            prefixLines(articleTextarea, (index) => `${index + 1}. `, 'List item');
                            break;
                        case 'table':
                            wrapSelection(
                                articleTextarea,
                                '',
                                '',
                                '| Column 1 | Column 2 |\n| --- | --- |\n| Value 1 | Value 2 |'
                            );
                            break;
                    }
                });
            }

            if (form && submitBtn && submitSpinner && submitText) {
                form.addEventListener('submit', function() {
                    submitBtn.disabled = true;
                    submitSpinner.classList.remove('d-none');
                    submitText.textContent = 'Saving...';
                });
            }

            if (embedVideoInput && deleteVideoBtn) {
                const syncDeleteVideoButton = () => {
                    deleteVideoBtn.disabled = !embedVideoInput.value.trim();
                };

                deleteVideoBtn.addEventListener('click', function() {
                    embedVideoInput.value = '';
                    if (embedVideoPositionSelect) {
                        embedVideoPositionSelect.value = 'inline';
                    }
                    syncDeleteVideoButton();
                    embedVideoInput.focus();
                });

                embedVideoInput.addEventListener('input', syncDeleteVideoButton);
                syncDeleteVideoButton();
            }

            // 1. Logic for adding more image blocks
            const addBtn = document.getElementById('add-more-images');
            const container = document.getElementById('image-container');

            if (addBtn && container) {
                addBtn.addEventListener('click', function() {
                    const originalBlock = container.querySelector('.image-block');
                    const newBlock = originalBlock.cloneNode(true);

                    // Clear the values
                    newBlock.querySelector('input[type="file"]').value = '';
                    newBlock.querySelector('input[type="text"]').value = '';

                    container.appendChild(newBlock);
                });
            }

            // 1b. Logic for adding more FAQ blocks
            const addFaqBtn = document.getElementById('add-more-faqs');
            const faqContainer = document.getElementById('faq-container');
            if (addFaqBtn && faqContainer) {
                addFaqBtn.addEventListener('click', function() {
                    const originalFaq = faqContainer.querySelector('.faq-block');
                    const newFaq = originalFaq.cloneNode(true);
                    // Reset inputs in the cloned block
                    newFaq.querySelectorAll('input').forEach(input => input.value = '');
                    // Update the label
                    const qLabel = newFaq.querySelector('.faq-question-label');
                    if (qLabel) {
                        // Count current blocks for numbering
                        const count = faqContainer.querySelectorAll('.faq-block').length + 1;
                        qLabel.textContent = `FAQ Question ${count}`;
                        qLabel.classList.remove('text-primary', 'fw-bold');
                    }
                    faqContainer.appendChild(newFaq);
                });
            }

            const addSourceBtn = document.getElementById('add-more-sources');
            const sourcesContainer = document.getElementById('sources-container');
            if (addSourceBtn && sourcesContainer) {
                addSourceBtn.addEventListener('click', function() {
                    const originalSource = sourcesContainer.querySelector('.source-block');
                    const newSource = originalSource.cloneNode(true);
                    newSource.querySelectorAll('input').forEach(input => input.value = '');
                    const titleLabel = newSource.querySelector('.source-title-label');
                    if (titleLabel) {
                        const count = sourcesContainer.querySelectorAll('.source-block').length + 1;
                        titleLabel.textContent = `Source Title ${count}`;
                        titleLabel.classList.remove('text-primary', 'fw-bold');
                    }
                    sourcesContainer.appendChild(newSource);
                });
            }

            // 2. Logic for deleting existing images
            const deleteButtons = document.querySelectorAll('.delete-image-btn');
            
            deleteButtons.forEach(button => {
                button.addEventListener('click', async function(e) {
                    const imageCard = this.closest('.image-card');
                    const articleId = imageCard.getAttribute('data-article-id');
                    const imageKey = imageCard.getAttribute('data-image-key');
                    
                    if (!confirm('Are you sure you want to delete this image?')) {
                        return;
                    }
                    
                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Deleting...';
                    
                    try {
                        const response = await fetch('/admin/article/delete-image', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                articleId: articleId,
                                imageKey: imageKey
                            })
                        });
                        
                        const result = await response.json();
                        
                        if (response.ok) {
                            imageCard.remove();
                        } else {
                            alert('Error: ' + (result.error || 'Failed to delete image'));
                            this.disabled = false;
                            this.innerHTML = '<i class="bi bi-trash me-1"></i>Delete';
                        }
                    } catch (error) {
                        console.error('Delete error:', error);
                        alert('Error: ' + error.message);
                        this.disabled = false;
                        this.innerHTML = '<i class="bi bi-trash me-1"></i>Delete';
                    }
                });
            });
        });
