extends ../common/layout

block layout-content
  .row.justify-content-center
    .col-lg-10
      .card.shadow-sm
        .card-body.p-4
          h1.h3.mb-4.text-center Add New Article

          //- Form targeting your Express submission route
          form#add-article-form(action="/admin/article/add/submit", method="post", enctype="multipart/form-data", autocomplete="off")
            
            // 1. Title
            .mb-3
              label.form-label(for="title") Title
              input.form-control(
                type="text",
                id="title",
                name="title",
                placeholder="Add hook title",
                autocomplete="off",
                required
              )

            // 2. Author
            if lockedAuthor
              .mb-3
                label.form-label Author
                input.form-control(
                  type="text",
                  value=lockedAuthor.name,
                  readonly
                )
                input(type="hidden", id="authorId", name="authorId", value=lockedAuthor._id)
                input(type="hidden", id="author", name="author", value=lockedAuthor.name)
                .form-text This article will be published under your linked author profile.
            else
              .mb-3
                label.form-label(for="authorId") Author
                select.form-select(
                  id="authorId",
                  name="authorId"
                )
                  option(value="") Select an author
                  each item in authors
                    option(value=item._id)= item.name
                .form-text Choose an existing author record. If left empty, the legacy author name below will be used.

              .mb-3
                label.form-label(for="author") Legacy Author Name
                input.form-control(
                  type="text",
                  id="author",
                  name="author",
                  value="",
                  placeholder="Optional if no author is selected above",
                  autocomplete="off"
                )


            // 3. Article Text
            .mb-3
              label.form-label(for="article-text") Article Text
              .card.border-0.bg-light.mb-2
                .card-body.py-2
                  .d-flex.flex-wrap.gap-2.article-markdown-toolbar(data-target="article-text")
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="bold") Bold
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="italic") Italic
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="quote") Quote
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="heading") Heading
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="link") Link
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="bullets") Bullets
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="numbered") Numbered List
                    button.btn.btn-outline-secondary.btn-sm(type="button", data-md-action="table") Table
              .form-text.mb-2 Use Markdown for formatting like bold, italics, quotes, headings, links, and lists.
              textarea.form-control(
                id="article-text",
                name="text",
                rows="10",
                placeholder="Write your full article here...",
                autocomplete="off"
              )

            // 6. FAQs (optional)
            .mb-4
              label.form-label.fw-bold Article FAQs (Optional)
              #faq-container
                .faq-block.border.rounded.p-3.mb-3.bg-light
                  .row
                    .col-md-6.mb-2.mb-md-0
                      label.form-label.small.fw-bold.text-primary.faq-question-label FAQ Question 1
                      input.form-control(
                        type="text",
                        name="faqQuestions",
                        placeholder="e.g., What is the best way to embed a YouTube video?"
                      )
                    .col-md-6
                      label.form-label.small FAQ Answer
                      input.form-control(
                        type="text",
                        name="faqAnswers",
                        placeholder="e.g., Use the YouTube embed code (iframe) in your article text."
                      )
              button#add-more-faqs.btn.btn-outline-secondary.btn-sm(type="button")
                | + Add Another Question

            // 6.1. Sources (optional)
            .mb-4
              label.form-label.fw-bold Article Sources (Optional)
              #sources-container
                .source-block.border.rounded.p-3.mb-3.bg-light
                  .row
                    .col-md-6.mb-2.mb-md-0
                      label.form-label.small.fw-bold.text-primary.source-title-label Source Title 1
                      input.form-control(
                        type="text",
                        name="sourceTitles",
                        placeholder="e.g., World Bank Report 2026"
                      )
                    .col-md-6
                      label.form-label.small Source URL
                      input.form-control(
                        type="url",
                        name="sourceUrls",
                        placeholder="https://example.com/report"
                      )
              button#add-more-sources.btn.btn-outline-secondary.btn-sm(type="button")
                | + Add Another Source

            // 4. Category
            .mb-3
              label.form-label(for="cat") Select Category
              select.form-select(id="cat", name="categoryId", required)
                option(value="") Select a category
                each cat in categories
                  option(value=cat._id)= cat.name

            // 5. Image & Caption Upload Section
            .mb-4
              label.form-label.fw-bold Article Images
              p.text-muted.small.mb-2 💡 Note: The first image will be used as the large Hero Image for the article card and header.
              
              #image-container
                // The first image block
                .image-block.border.rounded.p-3.mb-3.bg-light
                  .row
                    .col-md-6.mb-2.mb-md-0
                      label.form-label.small.fw-bold.text-primary.image-upload-label Upload Image 1 (Hero Image) *
                      input.form-control(
                        type="file",
                        name="images",
                        accept="image/*",
                        required
                      )
                    .col-md-6
                      label.form-label.small Image Caption (Source / Alt text)
                      input.form-control(
                        type="text",
                        name="alt",
                        placeholder="e.g., Photo by Unsplash"
                      )
              
              // Button to dynamically add more image/caption blocks
              button#add-more-images.btn.btn-outline-secondary.btn-sm(type="button")
                | + Add Another Image

            // 5.1. Embed Video (Optional)
            .mb-3
              label.form-label(for="embedVideo") Embed Video (YouTube or Embed URL)
              input.form-control(
                type="text",
                id="embedVideo",
                name="embedVideo",
                placeholder="Paste YouTube embed URL or iframe src..."
              )

            // 5.2. Video Position (Optional)
            .mb-3
              label.form-label(for="embedVideoPosition") Video Position
              select.form-select(id="embedVideoPosition", name="embedVideoPosition")
                option(value="inline" selected) Inline (inside article)
                option(value="hero") Hero (replace hero image)

            // 6. Buttons
            .d-flex.justify-content-end.gap-2.mt-4
              a.btn.btn-secondary(href="/admin/article") Cancel
              
              // Submit button with hidden spinner
              button#submit-btn.btn.btn-dark(type="submit")
                span#submit-spinner.spinner-border.spinner-border-sm.d-none.me-2(role="status", aria-hidden="true")
                span#submit-text Add Article

  // 🌟 SCRIPT TO HANDLE DYNAMIC IMAGES AND LOADING STATE
  script.
    document.addEventListener('DOMContentLoaded', function() {
      const draftKey = 'fastodigama.article.add.draft';

      // --- 1. HANDLE ADDING MORE IMAGES ---
      const addImageBtn = document.getElementById('add-more-images');
      const imageContainer = document.getElementById('image-container');
      let imageCount = 1; // Keep track of the number of images

      addImageBtn.addEventListener('click', function() {
        imageCount++;
        const originalBlock = imageContainer.querySelector('.image-block');
        const newBlock = originalBlock.cloneNode(true);

        // Reset inputs in the cloned block
        newBlock.querySelector('input[type="file"]').value = '';
        newBlock.querySelector('input[type="text"]').value = '';
        newBlock.querySelector('input[type="file"]').removeAttribute('required');

        // Update the label to signify it's a Body Image, not a Hero Image
        const label = newBlock.querySelector('.image-upload-label');
        if (label) {
          label.textContent = `Upload Image ${imageCount} (Body Image)`;
          label.classList.remove('text-primary', 'fw-bold');
        }

        imageContainer.appendChild(newBlock);
        saveDraft();
      });

      // --- 2. HANDLE ADDING MORE FAQS (MATCH EDIT PAGE LOGIC) ---
      const addFaqBtn = document.getElementById('add-more-faqs');
      const faqContainer = document.getElementById('faq-container');
      if (addFaqBtn && faqContainer) {
        addFaqBtn.addEventListener('click', function() {
          const originalFaq = faqContainer.querySelector('.faq-block');
          const newFaq = originalFaq.cloneNode(true);
          // Reset inputs in the cloned block
          newFaq.querySelectorAll('input').forEach(input => input.value = '');
          // Update the label
          const qLabel = newFaq.querySelector('.faq-question-label');
          if (qLabel) {
            // Count current blocks for numbering
            const count = faqContainer.querySelectorAll('.faq-block').length + 1;
            qLabel.textContent = `FAQ Question ${count}`;
            qLabel.classList.remove('text-primary', 'fw-bold');
          }
          faqContainer.appendChild(newFaq);
          saveDraft();
        });
      }

      // --- 2b. HANDLE ADDING MORE SOURCES ---
      const addSourceBtn = document.getElementById('add-more-sources');
      const sourcesContainer = document.getElementById('sources-container');
      const markdownToolbar = document.querySelector('.article-markdown-toolbar');
      const articleTextarea = document.getElementById('article-text');

      const wrapSelection = (textarea, before, after = before, fallback = 'text') => {
        const start = textarea.selectionStart ?? 0;
        const end = textarea.selectionEnd ?? 0;
        const selected = textarea.value.slice(start, end) || fallback;
        const replacement = `${before}${selected}${after}`;
        textarea.setRangeText(replacement, start, end, 'select');
        textarea.focus();
      };

      const prefixLines = (textarea, prefix, fallback = 'List item') => {
        const start = textarea.selectionStart ?? 0;
        const end = textarea.selectionEnd ?? 0;
        const selected = textarea.value.slice(start, end) || fallback;
        const replacement = selected
          .split('\n')
          .map((line, index) => `${typeof prefix === 'function' ? prefix(index) : prefix}${line || fallback}`)
          .join('\n');
        textarea.setRangeText(replacement, start, end, 'select');
        textarea.focus();
      };

      if (markdownToolbar && articleTextarea) {
        markdownToolbar.addEventListener('click', function(event) {
          const button = event.target.closest('[data-md-action]');
          if (!button) return;

          const action = button.getAttribute('data-md-action');
          switch (action) {
            case 'bold':
              wrapSelection(articleTextarea, '**', '**', 'bold text');
              break;
            case 'italic':
              wrapSelection(articleTextarea, '*', '*', 'italic text');
              break;
            case 'quote':
              prefixLines(articleTextarea, '> ', 'Quoted text');
              break;
            case 'heading':
              prefixLines(articleTextarea, '## ', 'Heading');
              break;
            case 'link':
              wrapSelection(articleTextarea, '[', '](https://example.com)', 'link text');
              break;
            case 'bullets':
              prefixLines(articleTextarea, '- ', 'List item');
              break;
            case 'numbered':
              prefixLines(articleTextarea, (index) => `${index + 1}. `, 'List item');
              break;
            case 'table':
              wrapSelection(
                articleTextarea,
                '',
                '',
                '| Column 1 | Column 2 |\n| --- | --- |\n| Value 1 | Value 2 |'
              );
              break;
          }

          saveDraft();
        });
      }

      if (addSourceBtn && sourcesContainer) {
        addSourceBtn.addEventListener('click', function() {
          const originalSource = sourcesContainer.querySelector('.source-block');
          const newSource = originalSource.cloneNode(true);
          newSource.querySelectorAll('input').forEach(input => input.value = '');
          const titleLabel = newSource.querySelector('.source-title-label');
          if (titleLabel) {
            const count = sourcesContainer.querySelectorAll('.source-block').length + 1;
            titleLabel.textContent = `Source Title ${count}`;
            titleLabel.classList.remove('text-primary', 'fw-bold');
          }
          sourcesContainer.appendChild(newSource);
          saveDraft();
        });
      }

      // --- 3. HANDLE FORM SUBMISSION & LOADING STATE ---
      const form = document.getElementById('add-article-form');
      const submitBtn = document.getElementById('submit-btn');
      const submitSpinner = document.getElementById('submit-spinner');
      const submitText = document.getElementById('submit-text');

      const ensureBlockCount = (container, addButton, selector, desiredCount) => {
        if (!container || !addButton) return;

        while (container.querySelectorAll(selector).length < desiredCount) {
          addButton.click();
        }
      };

      const collectNamedValues = (name) =>
        Array.from(form.querySelectorAll(`[name="${name}"]`)).map((field) => field.value || '');

      const applyNamedValues = (name, values) => {
        const fields = Array.from(form.querySelectorAll(`[name="${name}"]`));
        fields.forEach((field, index) => {
          field.value = values[index] || '';
        });
      };

      const collectDraft = () => ({
        title: document.getElementById('title')?.value || '',
        authorId: document.getElementById('authorId')?.value || '',
        author: document.getElementById('author')?.value || '',
        text: document.getElementById('article-text')?.value || '',
        categoryId: document.getElementById('cat')?.value || '',
        embedVideo: document.getElementById('embedVideo')?.value || '',
        embedVideoPosition: document.getElementById('embedVideoPosition')?.value || 'inline',
        faqQuestions: collectNamedValues('faqQuestions'),
        faqAnswers: collectNamedValues('faqAnswers'),
        sourceTitles: collectNamedValues('sourceTitles'),
        sourceUrls: collectNamedValues('sourceUrls'),
        alt: collectNamedValues('alt'),
        imageBlockCount: imageContainer ? imageContainer.querySelectorAll('.image-block').length : 1
      });

      const saveDraft = () => {
        localStorage.setItem(draftKey, JSON.stringify({
          savedAt: Date.now(),
          data: collectDraft()
        }));
      };

      const clearDraft = () => {
        localStorage.removeItem(draftKey);
      };

      const restoreDraft = () => {
        const rawDraft = localStorage.getItem(draftKey);
        if (!rawDraft) return;

        try {
          const parsed = JSON.parse(rawDraft);
          const data = parsed && parsed.data ? parsed.data : {};

          ensureBlockCount(faqContainer, addFaqBtn, '.faq-block', Math.max(1, (data.faqQuestions || []).length, (data.faqAnswers || []).length));
          ensureBlockCount(sourcesContainer, addSourceBtn, '.source-block', Math.max(1, (data.sourceTitles || []).length, (data.sourceUrls || []).length));
          ensureBlockCount(imageContainer, addImageBtn, '.image-block', Math.max(1, data.imageBlockCount || (data.alt || []).length || 1));

          if (document.getElementById('title')) document.getElementById('title').value = data.title || '';
          if (document.getElementById('authorId')) document.getElementById('authorId').value = data.authorId || '';
          if (document.getElementById('author')) document.getElementById('author').value = data.author || '';
          if (document.getElementById('article-text')) document.getElementById('article-text').value = data.text || '';
          if (document.getElementById('cat')) document.getElementById('cat').value = data.categoryId || '';
          if (document.getElementById('embedVideo')) document.getElementById('embedVideo').value = data.embedVideo || '';
          if (document.getElementById('embedVideoPosition')) document.getElementById('embedVideoPosition').value = data.embedVideoPosition || 'inline';

          applyNamedValues('faqQuestions', data.faqQuestions || []);
          applyNamedValues('faqAnswers', data.faqAnswers || []);
          applyNamedValues('sourceTitles', data.sourceTitles || []);
          applyNamedValues('sourceUrls', data.sourceUrls || []);
          applyNamedValues('alt', data.alt || []);
        } catch (error) {
          console.error('Failed to restore article draft:', error);
        }
      };

      Array.from(form.elements).forEach((field) => {
        if (!field.name || field.type === 'file' || field.type === 'submit' || field.type === 'button') {
          return;
        }

        const eventName = field.tagName === 'SELECT' ? 'change' : 'input';
        field.addEventListener(eventName, saveDraft);
        if (field.type === 'checkbox') {
          field.addEventListener('change', saveDraft);
        }
      });

      form.addEventListener('submit', function(e) {
        // Disable the button to prevent double-clicks
        submitBtn.disabled = true;
        // Show the spinner and change the text
        submitSpinner.classList.remove('d-none');
        submitText.textContent = 'Optimizing & Uploading...';
        clearDraft();
      });

      window.addEventListener('beforeunload', saveDraft);

      if (localStorage.getItem(draftKey)) {
        restoreDraft();
      }
    });
