extends common/layout

block layout-content
    .container.py-5
        .row.justify-content-center
            .col-lg-11
                if user
                    .d-flex.flex-column.flex-md-row.justify-content-between.align-items-md-end.mb-5.pb-4.border-bottom
                        .mb-3.mb-md-0
                            h1.fw-bold.mb-2 FASTODIGAMA
                            p.text-muted.mb-0.fs-5 Content Management Workspace
                        div
                            a.btn.btn-dark(href="/admin/article/add") New Article

                    .row.g-4.mb-5
                        .col-md-6.col-xl-3
                            .card.h-100
                                .card-body.p-4.d-flex.flex-column
                                    .d-flex.align-items-center.mb-3
                                        h5.mb-0 Articles
                                    p.text-muted.small.mb-4.flex-grow-1 Write, edit, and publish content.
                                    div
                                        a.btn.btn-outline-dark.w-100(href="/admin/article") Manage

                        .col-md-6.col-xl-3
                            .card.h-100
                                .card-body.p-4.d-flex.flex-column
                                    .d-flex.align-items-center.mb-3
                                        h5.mb-0 My Account
                                    p.text-muted.small.mb-4.flex-grow-1 Update your profile and account settings.
                                    div
                                        a.btn.btn-outline-dark.w-100(href="/user") Manage

                        if role === 'admin'
                            .col-md-6.col-xl-3
                                .card.h-100
                                    .card-body.p-4.d-flex.flex-column
                                        .d-flex.align-items-center.mb-3
                                            h5.mb-0 Categories
                                        p.text-muted.small.mb-4.flex-grow-1 Organize your content taxonomy.
                                        div
                                            a.btn.btn-outline-dark.w-100(href="/admin/category") Manage

                            .col-md-6.col-xl-3
                                .card.h-100
                                    .card-body.p-4.d-flex.flex-column
                                        .d-flex.align-items-center.mb-3
                                            h5.mb-0 Users
                                        p.text-muted.small.mb-4.flex-grow-1 Manage accounts and permissions.
                                        div
                                            a.btn.btn-outline-dark.w-100(href="/admin/users") Manage

                else
                    .row.justify-content-center.mt-5
                        .col-md-6.col-lg-5
                            .card
                                .card-body.p-5.text-center
                                    h2.fw-bold.mb-3 FASTOADMIN
                                    h4.mb-3 Sign in
                                    p.text-muted.mb-4 Use your administrator account to access the workspace.
                                    a.btn.btn-primary.w-100(href="/login") Continue to Login
