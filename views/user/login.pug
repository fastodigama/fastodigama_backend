extends ../common/layout

block layout-content
    .row.justify-content-center.mt-5
        .col-md-6.col-lg-4
            .card.shadow-sm
                .card-body.p-4
                    .text-center.mb-4
                        h2.fw-bold.mb-1 FASTODIGAMA
                        h5.text-muted.mb-0 Sign in

                    if err
                        .alert.alert-danger(role="alert") #{err}

                    form(action="/login", method="post", autocomplete="on")
                        .mb-3
                            label.form-label(for="u") Email
                            input.form-control(type="text", id="u", name="u", required)

                        .mb-4
                            label.form-label(for="pw") Password
                            input.form-control(type="password", id="pw", name="pw", required)

                        button.btn.btn-dark.w-100(type="submit") Login