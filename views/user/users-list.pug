extends ../common/layout

block layout-content
    //- User management page: list all users with password reset options
    .d-flex.justify-content-between.align-items-center.mb-4
        h1.mb-0 Manage Users
        .d-flex.gap-2
            a.btn.btn-dark.btn-sm(href="/register") Register New User
            a.btn.btn-outline-dark.btn-sm(href="/admin/article") Back to Admin

    //- Table view for users
    .table-responsive
        if users && users.length > 0
            table.table.table-striped.table-hover.align-middle
                //- Table headers
                thead.table-dark
                    tr
                        th(style="width: 28%") Username
                        th(style="width: 22%") First Name
                        th(style="width: 22%") Last Name
                        th(style="width: 13%") Role
                        th.text-center(style="width: 15%") Actions
                //- Table body: Loop through each user
                tbody
                    each user in users
                        tr
                            //- Username
                            td
                                strong #{user.user}
                            td
                                #{user.firstName}
                            td
                                #{user.lastName}
                            td
                                if user.role === 'admin'
                                    span.badge.text-bg-dark Admin
                                else if user.role === 'author'
                                    span.badge.text-bg-primary Author
                                else
                                    span.badge.text-bg-secondary User
                            td.text-center
                                .d-flex.gap-1.justify-content-center
                                    a.btn.btn-sm.btn-dark.fw-light.px-2.py-1.fs-7(href=`/admin/users/reset/${user._id}`) Reset
                                    a.btn.btn-sm.btn-info.fw-light.px-2.py-1.fs-7(href=`/admin/users/edit/${user._id}`) Edit
                                    a.btn.btn-sm.btn-danger.fw-light.px-2.py-1.fs-7(href=`/admin/users/delete/${user._id}`, onclick="return confirm('Are you sure you want to delete this user?')") Delete
        else
            .alert.alert-info No users found
