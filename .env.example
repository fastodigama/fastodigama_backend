# ===== SERVER CONFIGURATION =====
PORT=8888

# ===== SESSION SECRET =====
# Generate a random string for production: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSIONSECRET=your-session-secret-change-this-in-production

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/fastodigama

# ===== TIKTOK OAUTH CREDENTIALS =====
# Get these from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your-tiktok-client-key-here
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret-here

# Development: http://localhost:8888/api/reader/auth/tiktok/callback
# Production: https://yourdomain.com/api/reader/auth/tiktok/callback
TIKTOK_REDIRECT_URI=http://localhost:8888/api/reader/auth/tiktok/callback

# ===== FRONTEND URL =====
# Development
FRONTEND_URL=http://localhost:3000

# Production (uncomment when deploying)
# FRONTEND_URL=https://yourdomain.com

# ===== CLOUDFLARE R2 (Optional - for image uploads) =====
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-bucket-url.r2.dev
